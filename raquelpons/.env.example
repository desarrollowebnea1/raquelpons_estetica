# Base de datos (PostgreSQL / Supabase)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Auth JWT
NEXTAUTH_SECRET="cambia-esto-por-un-string-aleatorio-seguro-de-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"

# Supabase
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="tu-anon-key-de-supabase"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-de-supabase"
SUPABASE_STORAGE_BUCKET="raquelpons-estetica"

# Opcional: URL pública del sitio para Open Graph
NEXT_PUBLIC_SITE_URL="https://raquelponsestetica.com"
